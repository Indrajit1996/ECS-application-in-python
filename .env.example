# Dynatrace Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Your Dynatrace Environment ID (e.g., wkf10640)
DT_ENVIRONMENT_ID=your-environment-id

# Your Dynatrace API Token
DT_API_TOKEN=your-api-token

# Dynatrace Connection Point (optional, will default to live.dynatrace.com)
DT_CONNECTION_POINT=https://your-environment-id.apps.dynatrace.com

# Enable log content access
DT_LOG_CONTENT_ACCESS=1

# Application environment
ENVIRONMENT=local-development
